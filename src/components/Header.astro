---
import { PAGE_ACCENTS } from "@/lib/colors";
import Search from "@/components/Search.tsx";

interface Props {
  searchScope?: "global" | "devlog" | "articles" | "projects";
}

const { searchScope = "global" } = Astro.props;

const navItems = [
  { href: "/projects", label: "PROJECTS", accent: "projects" as const },
  { href: "/devlog", label: "DEVLOG", accent: "devlog" as const },
  { href: "/articles", label: "ARTICLES", accent: "articles" as const },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-border">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="/" class="font-mono text-base font-bold tracking-tight text-white transition-colors hover:text-white/80">
      tjw<span class="accent-dot">.</span>dev
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
      {navItems.map(({ href, label, accent }) => {
        const isActive = currentPath.startsWith(href);
        return (
          <a
            href={href}
            class:list={[
              "nav-link relative px-2 py-1 font-mono text-xs tracking-widest transition-colors sm:px-3 sm:text-sm",
              isActive ? "is-active" : "text-gray hover:text-white",
            ]}
            style={`--link-accent: var(--color-${PAGE_ACCENTS[accent]});`}
          >
            {label}
          </a>
        );
      })}
      <div class="ml-1 sm:ml-2">
        <Search client:idle scope={searchScope} />
      </div>
    </div>
  </nav>
</header>

<style>
  .accent-dot {
    color: var(--page-accent);
  }

  .nav-link.is-active {
    color: var(--link-accent);
  }

  /* Animated underline — always uses the target page's color */
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background: var(--link-accent);
    transition: width 0.25s cubic-bezier(0.16, 1, 0.3, 1),
                left 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link:hover::after,
  .nav-link.is-active::after {
    width: 100%;
    left: 0%;
  }

  .nav-link.is-active::after {
    opacity: 0.6;
  }
</style>
