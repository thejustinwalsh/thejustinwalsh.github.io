---
import { tagColor } from "@/lib/colors";

interface Props {
  tag: string;
  class?: string;
}

const { tag, class: className } = Astro.props;
const color = tagColor(tag);
---

<span
  class:list={["tag", className]}
  style={`--tag-color: ${color};`}
>
  {tag}
</span>

<style>
  .tag {
    display: inline-block;
    padding: 0.125rem 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--tag-color);
    border: 1px solid color-mix(in srgb, var(--tag-color) 25%, transparent);
    background: color-mix(in srgb, var(--tag-color) 5%, transparent);
  }
</style>
