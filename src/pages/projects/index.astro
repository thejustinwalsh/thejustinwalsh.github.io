---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Tag from "@/components/Tag.astro";
import LinkIcons from "@/components/LinkIcons.astro";
import { getCollection } from "astro:content";
import { getProjectOrder } from "@/lib/project-stats";

const isDev = import.meta.env.DEV;
const projects = (await getCollection("projects", ({ data }) => isDev || !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return getProjectOrder(b.id) - getProjectOrder(a.id);
  });
---

<BaseLayout title="Projects" accent="projects" searchScope="projects">
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <header class="animate-in mb-12">
      <h1 class="page-title font-mono text-3xl font-bold sm:text-4xl">Projects</h1>
      <p class="mt-2 text-gray">Things I've built and am building.</p>
    </header>

    {projects.length > 0 ? (
      <div class="space-y-6">
        {projects.map((project, i) => (
          <div
            class:list={[
              "entry-card group block",
              `animate-in delay-${Math.min(i + 1, 6)}`,
              project.data.draft && "draft-card"
            ]}
            onclick={!project.data.draft ? `window.location.href='/projects/${project.id}'` : undefined}
          >
            <div class="flex flex-col sm:flex-row sm:h-40">
              <div class="aspect-video w-full overflow-hidden sm:aspect-auto sm:h-full sm:w-60 sm:shrink-0">
                <img
                  src={project.data.hero || "/placeholder-project.svg"}
                  alt=""
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                  style="will-change: transform;"
                  loading="lazy"
                />
              </div>
              <div class="flex min-w-0 flex-1 flex-col justify-center p-5 sm:p-6">
                <div class="flex items-center gap-3">
                  <a href={!project.data.draft ? `/projects/${project.id}` : undefined} class="entry-title font-mono text-lg font-bold text-white transition-colors duration-200 truncate">
                    {project.data.title}
                  </a>
                  {project.data.draft && (
                    <span class="font-mono text-xs text-dim border border-border px-1.5 py-0.5">DRAFT</span>
                  )}
                  {project.data.status === "archived" && (
                    <span class="hidden font-mono text-xs text-dim sm:inline">archived</span>
                  )}
                  {project.data.links && (
                    <LinkIcons links={project.data.links} class="ml-auto shrink-0" />
                  )}
                </div>
                {project.data.description && (
                  <p class="description-clamp mt-2 text-sm text-gray">{project.data.description}</p>
                )}
                {project.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5 overflow-hidden max-h-7">
                    {project.data.tags.map((tag: string) => (
                      <Tag tag={tag} />
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      <div class="border border-border px-6 py-12 text-center">
        <p class="font-mono text-sm text-dim">Nothing here yet. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .draft-card {
    opacity: 0.4;
    pointer-events: none;
    filter: grayscale(100%);
  }
</style>
