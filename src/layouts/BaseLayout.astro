---
import "@/styles/global.css";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import type { PageAccent } from "@/lib/colors";
import { pageAccentVar } from "@/lib/colors";
import type { SearchScope } from "@/lib/search";

interface Props {
  title: string;
  description?: string;
  ogImage?: string | undefined;
  accent?: PageAccent;
  searchScope?: SearchScope;
  class?: string;
}

const {
  title,
  description = "Devlog & portfolio — game dev, creative tech, and interactive experiences.",
  ogImage = "/og-image.png",
  accent = "home",
  searchScope = "global",
  class: className = "",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const accentColor = pageAccentVar(accent);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="dark" />

    <title>{title === "Home" ? "tjw.dev" : `${title} — tjw.dev`}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title === "Home" ? "tjw.dev" : `${title} — tjw.dev`} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@thejustinwalsh" />
    <meta name="twitter:title" content={title === "Home" ? "tjw.dev" : `${title} — tjw.dev`} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    {import.meta.env.PROD && (
      <>
        <link rel="preconnect" href="https://metrics.tjw.dev" />
        <script is:inline defer src="https://metrics.tjw.dev/metrics.js" data-website-id="345cb050-cdc9-4278-8502-70825fdd4c2b"></script>
      </>
    )}
  </head>
  <body
    class:list={["flex min-h-screen flex-col bg-black", className]}
    style={`--page-accent: ${accentColor};`}
  >
    <Header searchScope={searchScope} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
