---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import Tag from "@/components/Tag.astro";
import ProjectPlaceholder from "@/components/ProjectPlaceholder.astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

interface Props {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const { title, description, tags, links, hero, heroVideo, status, draft } = entry.data;
const isDev = import.meta.env.DEV;

const devlogEntries = await getCollection("devlog", ({ data }) => {
  return data.project === entry.id;
});
devlogEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={title} description={description} ogImage={hero?.src} accent="projects" searchScope="projects">
  {/* Full-bleed hero */}
  <div class="relative aspect-21/9 w-full overflow-hidden border-b border-border">
    {heroVideo ? (
      <video
        autoplay
        loop
        muted
        playsinline
        poster={hero?.src}
        class="absolute inset-0 h-full w-full object-cover"
      >
        <source src={heroVideo.replace(/\.\w+$/, '.webm')} type="video/webm" />
        <source src={heroVideo} type="video/mp4" />
      </video>
    ) : hero ? (
      <Image
        src={hero}
        alt=""
        widths={[640, 960, 1280, 1920]}
        sizes="100vw"
        class="absolute inset-0 h-full w-full object-cover"
      />
    ) : (
      <ProjectPlaceholder name={title} variant="hero" class="absolute inset-0" />
    )}
    <div class="absolute inset-0 bg-linear-to-t from-black via-black/60 to-transparent" />
    <div class="absolute inset-x-0 bottom-0 mx-auto max-w-6xl px-4 pb-8 sm:px-6">
      <div class="flex items-end gap-4">
        <h1 class="font-mono text-4xl font-extrabold text-white sm:text-5xl md:text-6xl">
          {title}
        </h1>
        {status === "archived" && (
          <span class="status-badge mb-1.5 border px-2 py-0.5 font-mono text-xs">
            ARCHIVED
          </span>
        )}
        {isDev && draft && (
          <span class="draft-badge mb-1.5 border px-2 py-0.5 font-mono text-xs">
            DRAFT
          </span>
        )}
      </div>
    </div>
  </div>

  <article class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-[1fr_280px]">
      {/* Main content */}
      <div>
        {description && (
          <p class="mb-8 text-xl leading-relaxed text-gray">{description}</p>
        )}
        <div class="prose">
          <slot />
        </div>

        {/* Devlog entries */}
        {devlogEntries.length > 0 && (
          <div class="mt-12 border-t border-border pt-10 section-accented">
            <h2 class="mb-6 section-label font-mono text-xs font-semibold tracking-widest">DEVLOG</h2>
            <ul class="section-list">
              {devlogEntries.map((post) => (
                <li>
                  <a href={`/devlog/${post.id}`} class="section-row group flex items-baseline justify-between py-3 transition-all duration-200">
                    <span class="section-row-title text-sm text-white transition-colors duration-200">
                      {post.data.title}
                    </span>
                    <div class="shrink-0 pl-4 flex items-center gap-2 font-mono text-xs text-dim">
                      <time datetime={post.data.date.toISOString()}>
                        {new Date(post.data.date).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                      </time>
                      {post.data.tags.length > 0 && (
                        <>
                          <span class="text-border-bright">/</span>
                          <span>{post.data.tags[0]}</span>
                        </>
                      )}
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>

      {/* Sidebar — links & metadata */}
      <aside class="space-y-8 lg:border-l lg:border-border lg:pl-8">
        {/* Quick links with icons */}
        {links && (
          <div>
            <h2 class="mb-3 font-mono text-xs font-semibold tracking-widest text-dim">LINKS</h2>
            <div class="space-y-2">
              {links.live && (
                <a
                  href={links.live}
                  target="_blank"
                  rel="noopener"
                  class="sidebar-link flex items-center gap-2 font-mono text-sm transition-colors hover:text-white"
                >
                  <span class="text-dim">→</span> Website
                </a>
              )}
              {links.repo && (
                <a
                  href={links.repo}
                  target="_blank"
                  rel="noopener"
                  class="sidebar-link flex items-center gap-2 font-mono text-sm transition-colors hover:text-white"
                >
                  <span class="text-dim">→</span> Source
                </a>
              )}
              {links.docs && (
                <a
                  href={links.docs}
                  target="_blank"
                  rel="noopener"
                  class="sidebar-link flex items-center gap-2 font-mono text-sm transition-colors hover:text-white"
                >
                  <span class="text-dim">→</span> Docs
                </a>
              )}
              {links.discord && (
                <a
                  href={links.discord}
                  target="_blank"
                  rel="noopener"
                  class="sidebar-link flex items-center gap-2 font-mono text-sm transition-colors hover:text-white"
                >
                  <span class="text-dim">→</span> Discord
                </a>
              )}
              {links.store && (
                <a
                  href={links.store}
                  target="_blank"
                  rel="noopener"
                  class="sidebar-link flex items-center gap-2 font-mono text-sm transition-colors hover:text-white"
                >
                  <span class="text-dim">→</span> Store
                </a>
              )}
            </div>
          </div>
        )}

        {/* Tags */}
        {tags && tags.length > 0 && (
          <div>
            <h2 class="mb-3 font-mono text-xs font-semibold tracking-widest text-dim">STACK</h2>
            <div class="flex flex-wrap gap-1.5">
              {tags.map((tag: string) => (
                <Tag tag={tag} />
              ))}
            </div>
          </div>
        )}
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .status-badge {
    color: var(--page-accent);
    border-color: color-mix(in srgb, var(--page-accent) 30%, transparent);
    background: color-mix(in srgb, var(--page-accent) 10%, transparent);
  }
  .draft-badge {
    color: var(--color-dim);
    border-color: var(--color-border);
    background: color-mix(in srgb, var(--color-dim) 10%, transparent);
  }
  .sidebar-link {
    color: var(--page-accent);
  }
  .section-accented {
    --section-accent: var(--page-accent);
  }
  .section-label {
    color: color-mix(in srgb, var(--section-accent) 60%, var(--color-dim));
  }
  .section-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .section-row {
    border-top: 1px solid var(--color-border);
  }
  .section-list > :last-child > .section-row,
  .section-list > :last-child.section-row {
    border-bottom: 1px solid var(--color-border);
  }
  .section-row:hover {
    position: relative;
    z-index: 1;
    border-top-color: color-mix(in srgb, var(--section-accent) 30%, transparent);
    background: color-mix(in srgb, var(--section-accent) 3%, transparent);
    box-shadow: inset 0 -1px 0 color-mix(in srgb, var(--section-accent) 30%, transparent);
  }
  .group:hover .section-row-title {
    color: var(--section-accent);
  }
</style>
