---
import BaseLayout from "./BaseLayout.astro";
import Tag from "@/components/Tag.astro";
import type { CollectionEntry } from "astro:content";
import { getEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"devlog">;
}

const { entry } = Astro.props;
const { title, description, date, tags, project } = entry.data;

const isDev = import.meta.env.DEV;
const projectEntry = project ? await getEntry("projects", project) : null;
const showProject = projectEntry && (isDev || !projectEntry.data.draft);

const formattedDate = new Date(date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<BaseLayout title={title} description={description} accent="devlog" searchScope="devlog">
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <header class="mb-12">
      <div class="mb-4 flex items-center gap-3 font-mono text-xs tracking-widest text-dim">
        <time datetime={date.toISOString()}>{formattedDate.toUpperCase()}</time>
        {showProject && (
          <>
            <span class="text-border-bright">/</span>
            <a href={`/projects/${project}`} class="accent-link transition-colors hover:text-white">
              {projectEntry.data.title.toUpperCase()}
            </a>
          </>
        )}
      </div>
      <h1 class="font-mono text-3xl font-bold leading-tight text-white sm:text-4xl">
        {title}
      </h1>
      {description && (
        <p class="mt-3 text-lg leading-relaxed text-gray">{description}</p>
      )}
      {tags && tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag: string) => (
            <Tag tag={tag} />
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .accent-link {
    color: var(--page-accent);
  }
</style>
